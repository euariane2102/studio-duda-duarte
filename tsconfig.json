{
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "skipLibCheck": true,
    "strict": true
  }
}
